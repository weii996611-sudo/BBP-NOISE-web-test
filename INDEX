    function toggleMenuSocial(event) {
      if (event) event.stopPropagation();
    
      const pop = document.getElementById("menu-social-pop");
      const logoCard = document.querySelector(".menu-logo-card");
    
      if (!pop || !logoCard) return;
    
      const isOpen = pop.classList.toggle("show");
      logoCard.classList.toggle("social-open", isOpen);
