<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>BBPATROL 黑箱糾察隊</title>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    /* ---------------------------------------------------
       1. 核心變數設定 (LOGO 配色：黑、白、藍、紅)
    --------------------------------------------------- */
    :root {
      --bg-dark: #030303;        /* 極深黑底 */
      --card-bg: #0A0A0C;        /* 卡片深灰底 */
      --tech-blue: #1A56DB;      /* 科技藍 */
      --tech-blue-glow: rgba(26, 86, 219, 0.2);
      --tech-red: #E11D48;       /* 警示紅 */
      --tech-red-glow: rgba(225, 29, 72, 0.2);
      --tech-white: #FFFFFF;     /* 純白 */
      --tech-gray: #1F2937;      /* 邊框灰 */
      --text-muted: #9CA3AF;     /* 次要文字灰 */
    }

    * {
      box-sizing: border-box;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--tech-white);
      font-family: 'PingFang TC', 'Microsoft JhengHei', ui-sans-serif, system-ui, sans-serif;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      height: 100vh;
      height: 100dvh;
      overflow: hidden;
    }
    .btn-icon {
      width: 16px;
      height: 16px;
      object-fit: contain;
      vertical-align: -3px;
      margin-right: 6px;
    }

    /* ---------------------------------------------------
       2. 頂部導覽列 (Header)
    --------------------------------------------------- */
    #header {
      background-color: var(--bg-dark);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--tech-gray);
      flex-shrink: 0;
      gap: 12px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
      z-index: 10;
    }

    .brand-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      user-select: none;
    }

    .brand-title {
      margin: 0;
      font-size: 1.4rem;
      font-weight: 900;
      letter-spacing: 2px;
      line-height: 1.1;
      color: var(--tech-white);
    }

    .brand-subtitle {
      color: var(--tech-white);
      font-size: 0.95rem;
      text-transform: none;
      margin-top: 6px;
      letter-spacing: 2px;
      font-weight: 800;
      text-align: center;
    }

    .header-actions {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-shrink: 0;
    }

    /* 頂部按鈕統一風格 */
    .notify-header-btn,
    .back-btn,
    .refresh-btn {
      background-color: transparent;
      color: var(--tech-white);
      border: 1px solid var(--tech-blue);
      border-radius: 6px; /* 改為微圓角，更具科技感 */
      padding: 6px 14px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s ease;
    }

    .notify-header-btn { display: none !important; }
    .back-btn, .refresh-btn { display: none; }

    .notify-header-btn:active,
    .back-btn:active,
    .refresh-btn:active {
      background-color: var(--tech-blue-glow);
    }

    /* ---------------------------------------------------
       3. 主選單 (Menu Screen)
    --------------------------------------------------- */
    #main-wrapper {
      flex: 1;
      position: relative;
      width: 100%;
      min-height: 0;
    }

    #menu-screen {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 22px;
      padding: 20px;
      height: 100%;
      overflow-y: auto;
      /* 乾淨的背景，只留極微弱的藍光點綴 */
      background: radial-gradient(circle at 50% 0%, var(--tech-blue-glow), transparent 50%), var(--bg-dark);
    }

    .menu-hero {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    /* LOGO 容器極簡化 */
    .menu-logo-card {
      position: relative;
      width: 140px;
      height: 140px;
      border-radius: 20px;
      background: var(--tech-white);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      border: 2px solid var(--tech-gray);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.8);
    }
    .menu-logo-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    
    .menu-logo-card {
      cursor: pointer;
      z-index: 2;
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease,
        filter 0.18s ease;
    }
    
    .menu-logo-card:active {
      transform: scale(0.94);
      filter: brightness(0.92);
    }
    
    .menu-logo-card.social-open {
      box-shadow:
        0 8px 30px rgba(0, 0, 0, 0.8),
        0 0 22px rgba(26, 86, 219, 0.45);
    }
    
    .menu-social-pop {
      position: absolute;
      right: calc(100% + 48px);
      top: 50%;
      transform: translateY(-50%) translateX(16px);
      display: flex;
      flex-direction: column;
      gap: 10px;
      opacity: 0;
      pointer-events: none;
      transition:
        opacity 0.2s ease,
        transform 0.2s ease;
      z-index: 3;
    }
    
    .menu-social-pop.show {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(-50%) translateX(0);
    }
    
    .menu-social-pop .social-link {
      width: 42px;
      height: 42px;
      box-shadow:
        0 8px 18px rgba(0, 0, 0, 0.45),
        0 0 12px rgba(26, 86, 219, 0.16);
    }
    
    .menu-social-pop .social-link:hover {
      transform: translateY(-2px) scale(1.08);
    }
    
    .menu-social-pop .social-link:active {
      transform: scale(0.9);
    }
    .menu-logo {
      width: 100px;
      height: 100px;
      object-fit: contain;
    }

    .menu-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--tech-white);
      border: 1px solid var(--tech-blue);
      background: var(--tech-blue-glow);
      border-radius: 4px; /* 方正科技感 */
      padding: 4px 12px;
      font-size: 0.7rem;
      letter-spacing: 2px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .menu-title {
      font-size: 1.5rem;
      font-weight: 900;
      letter-spacing: 2px;
      color: var(--tech-white);
    }
    .store-link-group {
      position: absolute;
      top: 0;
      right: -84px;
      width: 58px;
      height: 140px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
      gap: 0;
      margin-top: 0;
      flex-wrap: nowrap;
    }
    
    .store-link {
      width: 58px;
      height: 58px;
      min-width: 0;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      overflow: visible;
      text-decoration: none;
      background: transparent;
      border: none;
      padding: 0;
      transition:
        transform 0.18s ease,
        filter 0.18s ease,
        box-shadow 0.18s ease;
    }
    
    .store-link img {
      width: 58px;
      height: 58px;
      object-fit: contain;
      display: block;
    }
    .store-link:hover {
      transform: translateY(-2px) scale(1.08);
      filter: brightness(1.16);
      box-shadow: 0 0 12px rgba(26, 86, 219, 0.35);
    }
    
    .store-link:active {
      transform: scale(0.9);
      filter: brightness(0.9);
    }
    .home-footer {
      width: 100%;
      max-width: 520px;
      margin-top: 4px;
      padding: 14px 0 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 13px;
    }
    
    .follow-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--tech-white);
      letter-spacing: 1px;
    }
    
    .social-link-group {
      display: flex;
      justify-content: center;
      gap: 14px;
      align-items: center;
    }
    
    .social-link {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: #ffffff;
      font-weight: 900;
      font-size: 1rem;
      box-shadow: 0 8px 22px rgba(0, 0, 0, 0.35);
      transition: transform 0.18s ease, opacity 0.18s ease;
    }
    
    .social-link:hover {
      transform: translateY(-2px) scale(1.04);
    }
    .social-link img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .social-link.fb {
      background: #1877f2;
      font-size: 1.7rem;
      font-family: Arial, sans-serif;
    }
    
    .social-link.ig {
      background: radial-gradient(circle at 30% 110%, #fdf497 0%, #fdf497 12%, #fd5949 38%, #d6249f 62%, #285aeb 100%);
      font-size: 1.55rem;
    }
    
    .social-link.threads {
      background: #ffffff;
      color: #000000;
      font-size: 1.55rem;
    }
    
    .social-link.line {
      background: #06c755;
      font-size: 0.68rem;
      letter-spacing: -0.5px;
    }
    
    .copyright {
      font-size: 0.78rem;
      color: var(--text-muted);
      text-align: center;
      letter-spacing: 0.5px;
    }

    /* 區域按鈕網格 */
    .region-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      width: 82%;
      max-width: 430px;
    }

    .region-btn {
      position: relative;
      min-height: 72px;
      background: var(--card-bg);
      border: 1px solid var(--tech-gray);
      border-radius: 12px;
      color: var(--tech-white);
      padding: 14px;
      cursor: pointer;
      user-select: none;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 8px;
      text-align: center;
      transition: all 0.2s ease;
    }

    .region-name {
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: 1px;
      text-align: center;
    }

    .region-arrow {
      color: var(--tech-blue);
      font-size: 0.8rem;
      font-weight: 600;
    }

    .region-btn:hover {
      transform: translateY(-2px);
      border-color: var(--tech-blue);
      box-shadow: 0 4px 15px var(--tech-blue-glow);
    }

    .region-btn:active {
      transform: scale(0.98);
      background: var(--tech-blue-glow);
    }

    /* ---------------------------------------------------
       4. 數據頁面 (Data Screen) & 卡片
    --------------------------------------------------- */
    #area-filter-bar {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 18px;
      z-index: 6;
      display: none;
      gap: 10px;
      overflow-x: auto;
      padding: 0 70px 10px 24px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      scroll-padding-right: 70px;
    }
    
    #area-filter-bar::-webkit-scrollbar {
      display: none;
    }
    #area-filter-bar::after {
      content: "";
      position: fixed;
      right: 0;
      bottom: 18px;
      width: 64px;
      height: 52px;
      pointer-events: none;
      background: linear-gradient(90deg, rgba(3, 3, 3, 0), var(--bg-dark) 72%);
      z-index: 7;
    }
    
    .area-filter-btn {
      flex: 0 0 auto;
      background: rgba(10, 10, 12, 0.92);
      color: var(--tech-white);
      border: 1px solid var(--tech-gray);
      border-radius: 999px;
      padding: 9px 16px;
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 1px;
      cursor: pointer;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
      transition: all 0.2s ease;
    }
    
    .area-filter-btn.active {
      color: var(--tech-white);
      border-color: var(--tech-blue);
      background: linear-gradient(135deg, var(--tech-blue), var(--tech-red));
    }
    
    .area-filter-btn:active {
      transform: scale(0.96);
    }
    #data-screen {
      display: none;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      height: 100%;
      padding: 24px 24px 110px;
      gap: 24px;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;
    }

    #data-screen {
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      scroll-behavior: smooth;
    }
    
    /* 電腦版顯示橫向捲軸 */
    #data-screen::-webkit-scrollbar {
      display: block;
      height: 10px;
    }
    
    #data-screen::-webkit-scrollbar-track {
      background: #050505;
    }
    
    #data-screen::-webkit-scrollbar-thumb {
      background: linear-gradient(90deg, var(--tech-blue), var(--tech-red));
      border-radius: 999px;
    }
    
    #data-screen::-webkit-scrollbar-thumb:hover {
      background: linear-gradient(90deg, #2f6bff, #ff2f62);
    }
    /* 電腦版：降低吸附強度，讓滑鼠滾輪更順 */
    @media (min-width: 769px) {
      #data-screen {
        scroll-snap-type: x proximity;
      }
    }
    
    /* 手機版：保留原本一張一張吸附 */
    @media (max-width: 768px) {
      #data-screen {
        scroll-snap-type: x mandatory;
      }
    }
    /* 手機版維持隱藏捲軸 */
    @media (max-width: 768px) {
      #data-screen::-webkit-scrollbar {
        display: none;
      }
    }

    .bb-card {
      /* 1. 簡化背景與邊框色調：採用高級灰色調 */
      background:
        linear-gradient(rgba(20, 20, 22, 0.65), rgba(20, 20, 22, 0.65)) padding-box,
        solid 1px rgba(255, 255, 255, 0.08) border-box; /* 移除藍紅漸變，改為細緻的灰色單色邊框 */
    
      /* 2. 提升設計感：加入高級玻璃態效果 (Glassmorphism) */
      backdrop-filter: blur(12px); /* 增加背景模糊 */
      -webkit-backdrop-filter: blur(12px);
    
      /* 3. 優化細節： */
      border: none; /* 原本 2px 透明邊框改為 1px 灰色 solid */
      border-radius: 16px; /* 稍微縮小圓角，更顯俐落 */
      width: 80vw;
      max-width: 340px;
      min-width: 280px;
      flex-shrink: 0;
      scroll-snap-align: center;
      padding: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
      overflow: hidden;
      transition: all 0.4s ease;
    
      /* 4. 簡化陰影與發光：統一為一個更柔和、單色的深灰色陰影 */
      box-shadow:
        0 10px 40px rgba(0, 0, 0, 0.6), /* 主要深色陰影 */
        0 0 1px rgba(255, 255, 255, 0.05); /* 移除彩色發光，只留極微弱的灰白色邊框微光 */
    }
    
    /* 5. 進一步簡化內部分割線條與元素色調：以下代碼僅供參考，用於優化按鈕 */
    /* 例如，您可以將按鈕的文字顏色改為白色，並保留邊框顏色，以保持整體簡潔 */
    .share-card-btn {
      border: 1px solid var(--tech-blue);
      color: #FFFFFF; /* 改為白色，更清晰 */
    }
    
    .remove-card-btn {
      border: 1px solid var(--tech-red);
      color: #FFFFFF; /* 改為白色，更清晰 */
    }

    /* 卡片頂部的紅藍科技線條點綴 */
    .bb-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--tech-blue) 0%, var(--tech-red) 100%);
    }

    .bb-card.fade-out {
      opacity: 0;
      transform: scale(0.8);
      width: 0;
      min-width: 0;
      padding: 0;
      margin: 0;
      border: 0 solid transparent;
    }

    .bb-title {
      font-size: 1.85rem;
      color: var(--tech-white);
      margin-bottom: 18px;
      font-weight: 900;
      text-align: center;
      letter-spacing: 2px;
    }

    .image-container {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 16px;
      background-color: var(--bg-dark);
      border: 1px solid var(--tech-gray);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      touch-action: pan-y;
      user-select: none;
    }

    .image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover; /* 改為 cover 讓地圖填滿更俐落 */
      display: block;
    }
    .image-container {
      position: relative;
    }
    
    .image-nav-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 34px;
      height: 34px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      background: rgba(0, 0, 0, 0.55);
      color: #ffffff;
      font-size: 1.2rem;
      font-weight: 900;
      cursor: pointer;
      z-index: 3;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .image-nav-btn.left {
      left: 8px;
    }
    
    .image-nav-btn.right {
      right: 8px;
    }
    
    .image-dots {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 8px;
      display: flex;
      justify-content: center;
      gap: 6px;
      z-index: 3;
    }
    
    .image-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.45);
    }
    
    .image-dot.active {
      background: #ffffff;
    }
    .bb-body {
      font-size: 1rem;
      line-height: 1.5;
      text-align: center;
      color: var(--tech-white);
      margin-bottom: 8px;
      word-break: break-word;
      font-weight: 500;
    }

    .bb-meta {
      color: var(--text-muted);
      font-size: 0.8rem;
      margin-bottom: 20px;
      text-align: center;
      font-family: monospace; /* 時間加上一點科技數據感 */
    }

    /* 卡片按鈕 */
    .card-control-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 100%;
    }

    .share-card-btn,
    .remove-card-btn {
      background-color: transparent;
      border-radius: 6px;
      padding: 10px 15px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      width: 100%;
      text-align: center;
    }
    .share-card-btn .btn-icon {
      filter: brightness(0) invert(1);
    }
    .share-card-btn {
      color: var(--tech-white);
      border: 1px solid var(--tech-blue);
    }
    .share-card-btn:active {
      background-color: var(--tech-blue);
      color: var(--tech-white);
    }

    .remove-card-btn {
      color: var(--tech-red);
      border: 1px solid var(--tech-red);
    }
    .remove-card-btn:active:not(:disabled) {
      background-color: var(--tech-red);
      color: var(--tech-white);
    }
    .remove-card-btn:disabled {
      cursor: not-allowed;
      border-color: var(--tech-gray);
      color: var(--text-muted);
      background: transparent;
    }

    /* ---------------------------------------------------
       5. 系統文字與通知 Modal
    --------------------------------------------------- */
    #no-data, #loading-text {
      width: 100%;
      text-align: center;
      color: var(--text-muted);
      font-size: 1rem;
      position: absolute;
      top: 50%;
      left: 0;
      transform: translateY(-50%);
      letter-spacing: 1px;
    }
    
    #no-data {
      cursor: pointer;
    }
    
    .no-data-home {
      display: inline-block;
      margin-top: 10px;
      color: var(--tech-blue);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .error-text { color: var(--tech-red) !important; }

    .notify-modal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0, 0, 0, 0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      backdrop-filter: blur(4px);
    }

    .notify-box {
      width: 100%;
      max-width: 320px;
      background: var(--card-bg);
      border: 1px solid var(--tech-gray);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
      /* 頂部藍線 */
      border-top: 3px solid var(--tech-blue);
    }

    .notify-icon { font-size: 2rem; margin-bottom: 12px; }
    
    .notify-title {
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--tech-white);
      margin-bottom: 10px;
    }

    .notify-text {
      font-size: 0.9rem;
      line-height: 1.6;
      color: var(--text-muted);
      margin-bottom: 20px;
    }

    .notify-actions {
      display: flex;
      flex-direction: column; /* 改為上下排列更乾淨 */
      gap: 10px;
      margin-bottom: 12px;
    }

    .notify-allow-btn, .notify-later-btn {
      border-radius: 6px;
