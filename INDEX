    function showLoading(text) {
      const loadingText = document.getElementById("loading-text");
      loadingText.classList.remove("error-text");
      loadingText.textContent = text || "[ 系統連線中... ]";
      loadingText.style.display = "block";
    }

    function showError(text) {
      const loadingText = document.getElementById("loading-text");
      loadingText.classList.add("error-text");
      loadingText.textContent = text || "連線失敗";
      loadingText.style.display = "block";
    }

    function hideLoading() {
      document.getElementById("loading-text").style.display = "none";
    }

    function getDeviceId() {
      let deviceId = localStorage.getItem("bbp_noise_device_id");
      if (!deviceId) {
        deviceId = "dev_" + Date.now().toString(36) + "_" + Math.random().toString(36).slice(2, 12);
        localStorage.setItem("bbp_noise_device_id", deviceId);
      }
      return deviceId;
    }

    function shouldShowNotifyPrompt() {
      if (notifyPromptShownThisSession) return false;
      const lastClosedAt = Number(localStorage.getItem("bbp_notify_closed_at") || "0");
      const threeDays = 3 * 24 * 60 * 60 * 1000;
      if (lastClosedAt && Date.now() - lastClosedAt < threeDays) return false;
      if ("Notification" in window && Notification.permission === "granted") return false;
      return true;
    }

    function showNotifyModal(forceShow) {
      if (!forceShow && !shouldShowNotifyPrompt()) return;
      notifyPromptShownThisSession = true;
      const modal = document.getElementById("notify-modal");
      if (modal) modal.style.display = "flex";
    }

    function closeNotifyModal(remember) {
      const modal = document.getElementById("notify-modal");
      if (modal) modal.style.display = "none";
      if (remember) localStorage.setItem("bbp_notify_closed_at", String(Date.now()));
    }

    function scheduleNotifyPrompt() {
      if (notifyPromptTimer) return;
      notifyPromptTimer = setTimeout(function () { showNotifyModal(); }, 7000);
    }

    function showNotifyPromptAfterRegionClick() {
      setTimeout(function () { showNotifyModal(); }, 800);
    }

    async function requestSiteNotification() {
      if (!("Notification" in window)) {
        alert("目前瀏覽器不支援網站通知。iPhone 使用者建議用 Safari 開啟，並將本頁加入主畫面。");
        closeNotifyModal(true);
        return;
      }
      if (Notification.permission === "denied") {
        alert("你已封鎖網站通知。若要開啟，請到瀏覽器設定中重新允許通知。");
        closeNotifyModal(true);
        return;
      }
      try {
        const permission = await Notification.requestPermission();
        if (permission === "granted") {
          localStorage.setItem("bbp_notify_enabled", "true");
          closeNotifyModal(false);
          updateNotifyHeaderButton();
          try {
            new Notification("BBPATROL 系統連線成功", { body: "當有新的測速/噪音熱點時，將自動推播通知。" });
          } catch (e) {}
        } else {
          closeNotifyModal(true);
        }
      } catch (error) {
        alert("通知權限開啟失敗，請稍後再試。");
        closeNotifyModal(true);
      }
    }

    function updateNotifyHeaderButton() {
      const btn = document.getElementById("notify-header-btn");
      if (!btn) return;
      if ("Notification" in window && Notification.permission === "granted") {
        btn.textContent = "🔔 通知已開啟";
        btn.disabled = true;
        btn.style.opacity = "0.4";
        btn.style.borderColor = "var(--tech-gray)";
        btn.style.color = "var(--tech-white)";
        return;
      }
      btn.textContent = "🔔 接收通知";
      btn.disabled = false;
      btn.style.opacity = "1";
    }

    function formatCreatedAt(dateString) {
      if (!dateString) return "";
      const date = new Date(dateString);
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }
    function getAreaTitle(text) {
      const rawText = String(text || "").trim();
    
      // 取前 4 個中文字，忽略空格、數字、符號
      const chineseChars = rawText.match(/[\u4e00-\u9fff]/g);
    
      if (chineseChars && chineseChars.length >= 4) {
        return chineseChars.slice(0, 4).join("");
      }
    
      // 如果資料不足 4 個中文字，就退回取前 4 個字元
      return rawText.slice(0, 4) || "紀錄檔";
    }
    function getBodyTextWithoutArea(text) {
      const rawText = String(text || "").trim();
    
      let chineseCount = 0;
      let cutIndex = 0;
    
      for (let i = 0; i < rawText.length; i++) {
        if (/[\u4e00-\u9fff]/.test(rawText[i])) {
          chineseCount++;
        }
    
        if (chineseCount === 4) {
          cutIndex = i + 1;
          break;
        }
      }
    
      if (chineseCount >= 4) {
        return rawText.slice(cutIndex).trim();
      }
    
      return rawText;
    }
    function renderAreaFilterButtons(regionItems, activeArea) {
      const bar = document.getElementById("area-filter-bar");
      if (!bar) return;
    
      const areaList = [];
      const areaCountMap = {};
    
      regionItems.forEach(function (item) {
        const area = getAreaTitle(item.text);
    
        if (!area) return;
    
        if (!areaCountMap[area]) {
          areaCountMap[area] = 0;
          areaList.push(area);
        }
    
        areaCountMap[area]++;
      });
    
      if (areaList.length <= 1) {
        bar.innerHTML = "";
        bar.style.display = "none";
        return;
      }
    
      bar.innerHTML = "";
    
      const allBtn = document.createElement("button");
      allBtn.className = "area-filter-btn" + (!activeArea ? " active" : "");
      allBtn.type = "button";
      allBtn.textContent = "全部";
    
      allBtn.addEventListener("click", function () {
        filterData(currentRegion, "");
      });
    
      bar.appendChild(allBtn);
    
      areaList.forEach(function (area) {
        const count = areaCountMap[area] || 0;
        const displayText = count > 1 ? area + count : area;
    
        const btn = document.createElement("button");
        btn.className = "area-filter-btn" + (activeArea === area ? " active" : "");
        btn.type = "button";
        btn.textContent = displayText;
    
        btn.addEventListener("click", function () {
          filterData(currentRegion, area);
        });
    
        bar.appendChild(btn);
      });
    
      bar.style.display = "flex";
    }

    async function loadDataFromServer(callback) {
      if (!supabaseClient) {
        allData = [];
        showError("資料庫連線失敗，請檢查系統參數。");
        return;
      }
      try {
        const { data, error } = await supabaseClient
          .from("noise_reports")
          .select("id, text, image_url, image_urls, region, report_logs, report_count, is_active, created_at")
          .eq("is_active", true)
          .order("created_at", { ascending: false });

        if (error) throw error;

        allData = (data || []).map(function (item) {
          return {
            id: item.id,
            text: item.text || "",
            imageUrl: item.image_url || "",
            imageUrls: Array.isArray(item.image_urls) && item.image_urls.length > 0
              ? item.image_urls
              : (item.image_url ? [item.image_url] : []),
            region: item.region || "",
            reportLogs: item.report_logs || "",
            reportCount: item.report_count || 0,
            isActive: item.is_active,
            createdAt: item.created_at || ""
          };
        });

        if (typeof callback === "function") callback();
      } catch (error) {
        allData = [];
        showError("系統異常：" + error.message);
      }
    }

    function filterData(regionName, areaFilter = "", fromPopState = false) {
      currentRegion = regionName;
      currentAreaFilter = areaFilter;
    
      const dataScreen = document.getElementById("data-screen");
      const noData = document.getElementById("no-data");
    
      dataScreen.innerHTML = "";
      hideLoading();
    
      const regionItems = allData.filter(function (item) {
        return String(item.region).trim() === regionName;
      });
    
      renderAreaFilterButtons(regionItems, areaFilter);
    
      const filtered = areaFilter
        ? regionItems.filter(function (item) {
            return getAreaTitle(item.text) === areaFilter;
          })
        : regionItems;
    
      if (filtered.length > 0) {
        filtered.forEach(function (item, index) {
          const cardElement = createCardElement(item, index + 1, regionName);
          dataScreen.appendChild(cardElement);
        });
    
        dataScreen.style.display = "flex";
        noData.style.display = "none";
      } else {
        dataScreen.style.display = "none";
        noData.style.display = "block";
      }
    
      document.getElementById("menu-screen").style.display = "none";
      document.getElementById("back-btn").style.display = "block";
      document.getElementById("refresh-btn").style.display = "block";
    
      const cleanUrl =
        window.location.protocol +
        "//" +
        window.location.host +
        window.location.pathname +
        "?region=" +
        encodeURIComponent(regionName);
    
      if (!fromPopState) {
        window.history.pushState(
          { page: "region", region: regionName },
          "",
          cleanUrl
        );
      }
    
      showNotifyPromptAfterRegionClick();
    }

    function createCardElement(item, cardNumber, regionName) {
      const card = document.createElement("div");
      card.className = "bb-card";
      card.id = "card-box-" + item.id;

      const title = document.createElement("div");
      title.className = "bb-title";
      title.textContent = getAreaTitle(item.text);
      card.appendChild(title);

      const images = Array.isArray(item.imageUrls) && item.imageUrls.length > 0
        ? item.imageUrls
        : (item.imageUrl ? [item.imageUrl] : []);
      
      if (images.length > 0) {
        const imageContainer = document.createElement("div");
        imageContainer.className = "image-container";
      
        const img = document.createElement("img");
        let currentImageIndex = 0;
      
        img.src = images[currentImageIndex];
        img.alt = "系統快照";
        img.loading = "lazy";
      
        img.onerror = function () {
          imageContainer.style.display = "none";
        };
      
        imageContainer.appendChild(img);
      
        if (images.length > 1) {
          const leftBtn = document.createElement("button");
          leftBtn.className = "image-nav-btn left";
          leftBtn.type = "button";
          leftBtn.textContent = "‹";
      
          const rightBtn = document.createElement("button");
          rightBtn.className = "image-nav-btn right";
          rightBtn.type = "button";
          rightBtn.textContent = "›";
      
          const dots = document.createElement("div");
          dots.className = "image-dots";
      
          const dotElements = images.map(function (_, index) {
            const dot = document.createElement("span");
            dot.className = "image-dot" + (index === 0 ? " active" : "");
            dots.appendChild(dot);
            return dot;
          });
      
          function updateCarouselImage() {
            img.src = images[currentImageIndex];
          
            dotElements.forEach(function (dot, index) {
              dot.className = "image-dot" + (index === currentImageIndex ? " active" : "");
            });
          }
          
          function showPrevImage() {
            currentImageIndex =
              currentImageIndex === 0
                ? images.length - 1
                : currentImageIndex - 1;
          
            updateCarouselImage();
          }
          
          function showNextImage() {
            currentImageIndex =
              currentImageIndex === images.length - 1
                ? 0
                : currentImageIndex + 1;
          
            updateCarouselImage();
          }
          
          leftBtn.addEventListener("click", function (event) {
            event.stopPropagation();
            showPrevImage();
          });
          
          rightBtn.addEventListener("click", function (event) {
            event.stopPropagation();
            showNextImage();
          });
          
          let touchStartX = 0;
          let touchStartY = 0;
          let touchEndX = 0;
          let touchEndY = 0;
          
          imageContainer.addEventListener("touchstart", function (event) {
            if (!event.touches || event.touches.length === 0) return;
          
            touchStartX = event.touches[0].clientX;
            touchStartY = event.touches[0].clientY;
          }, { passive: true });
          
          imageContainer.addEventListener("touchend", function (event) {
            if (!event.changedTouches || event.changedTouches.length === 0) return;
          
            touchEndX = event.changedTouches[0].clientX;
            touchEndY = event.changedTouches[0].clientY;
          
            const diffX = touchEndX - touchStartX;
            const diffY = touchEndY - touchStartY;
          
            // 避免上下滑頁面時誤觸，必須是明顯左右滑才切圖
            if (Math.abs(diffX) < 45 || Math.abs(diffX) < Math.abs(diffY)) {
              return;
            }
          
            if (diffX > 0) {
              showPrevImage();
            } else {
              showNextImage();
            }
          }, { passive: true });
      
          imageContainer.appendChild(leftBtn);
          imageContainer.appendChild(rightBtn);
          imageContainer.appendChild(dots);
        }
      
        card.appendChild(imageContainer);
      }

      const body = document.createElement("div");
      body.className = "bb-body";
      body.textContent = getBodyTextWithoutArea(item.text);
      card.appendChild(body);

      const meta = document.createElement("div");
      meta.className = "bb-meta";
      const createdTime = formatCreatedAt(item.createdAt);
      meta.textContent = createdTime ? "T: " + createdTime : "";
      card.appendChild(meta);

      const controls = document.createElement("div");
      controls.className = "card-control-group";

      const shareBtn = document.createElement("button");
      shareBtn.className = "share-card-btn";
      shareBtn.type = "button";
      shareBtn.innerHTML = '<img src="https://sadnhsddereuhpfvdquk.supabase.co/storage/v1/object/sign/BBP%20LOGO/share.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8yNzI5Y2M5OC1mM2IzLTRhNGMtOTAzMC03M2M2MjZlNTM0NTIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJCQlAgTE9HTy9zaGFyZS5wbmciLCJpYXQiOjE3Nzk0MTU2MTMsImV4cCI6MTg3NDAyMzYxM30.ZuWXLgK9ohxg-YDP12NXf1Bsvj-0zwrr_DMKPRgonis" class="btn-icon"> 分享貼文';
      shareBtn.addEventListener("click", function () { shareCard(shareBtn, regionName, item.id); });

      const removeBtn = document.createElement("button");
      removeBtn.className = "remove-card-btn";
      removeBtn.type = "button";

      const localKey = "bbp_noise_reported_" + item.id;
      const lastReportedAt = Number(localStorage.getItem(localKey) || "0");
      const isCoolingDown = Date.now() - lastReportedAt < 10 * 60 * 1000;

      if (isCoolingDown) {
        removeBtn.disabled = true;
        removeBtn.textContent = "✓ 已送出通報";
      } else {
        removeBtn.innerHTML = '<img src="https://sadnhsddereuhpfvdquk.supabase.co/storage/v1/object/sign/BBP%20LOGO/delete-document.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8yNzI5Y2M5OC1mM2IzLTRhNGMtOTAzMC03M2M2MjZlNTM0NTIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJCQlAgTE9HTy9kZWxldGUtZG9jdW1lbnQucG5nIiwiaWF0IjoxNzc5NDE1NjUyLCJleHAiOjE4NzQwMjM2NTJ9.owSFEM6icP6Uduaj8wwtI8F0iO1zoW45J7qC5auXa8E" class="btn-icon"> 設備已撤離';
        removeBtn.addEventListener("click", function () { reportWithdraw(removeBtn, item.id); });
      }

      controls.appendChild(shareBtn);
      controls.appendChild(removeBtn);
      card.appendChild(controls);

      return card;
    }

    function showMenu(fromPopState = false) {
      currentRegion = "";
      document.getElementById("menu-screen").style.display = "flex";
      document.getElementById("data-screen").style.display = "none";
      document.getElementById("no-data").style.display = "none";
      document.getElementById("back-btn").style.display = "none";
      document.getElementById("refresh-btn").style.display = "none";
      const areaFilterBar = document.getElementById("area-filter-bar");
      if (areaFilterBar) {
        areaFilterBar.style.display = "none";
      }
      hideLoading();
      const cleanUrl =
        window.location.protocol +
        "//" +
        window.location.host +
        window.location.pathname;
      
      if (!fromPopState) {
        window.history.replaceState({ page: "home" }, "", cleanUrl);
      }
    }

    async function refreshCurrentRegion() {
      if (!currentRegion) return;
      const dataScreen = document.getElementById("data-screen");
      const noData = document.getElementById("no-data");
      noData.style.display = "none";
      dataScreen.style.display = "none";
      dataScreen.innerHTML = "";
      showLoading("[ 數據即時同步中... ]");
      await loadDataFromServer(function () {
        filterData(currentRegion, currentAreaFilter);
      });
    }

    async function shareCard(buttonObj, region, reportId) {
      const baseUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
      const shareUrl = baseUrl + "?region=" + encodeURIComponent(region) + "&id=" + encodeURIComponent(reportId);
    
      const shareText = "快來看這裡新增的噪音偵測吧!";
      const fullShareText = shareText + "\n" + shareUrl;
    
      try {
        if (navigator.share) {
          await navigator.share({
            text: shareText,
            url: shareUrl
          });
          return;
        }
    
        await navigator.clipboard.writeText(fullShareText);
        showShareSuccess(buttonObj);
    
      } catch (error) {
        try {
          await navigator.clipboard.writeText(fullShareText);
          showShareSuccess(buttonObj);
        } catch (copyError) {
          alert("連結複製失敗。");
        }
      }
    }
    // 狀態顏色修改為對應的科技藍
    function showShareSuccess(buttonObj) {
      const oldText = buttonObj.textContent;
      buttonObj.textContent = "✓ 已複製連結";
      buttonObj.style.borderColor = "var(--tech-blue)";
      buttonObj.style.color = "var(--tech-white)";
      buttonObj.style.backgroundColor = "var(--tech-blue)";

      setTimeout(function () {
        buttonObj.innerHTML = oldText || '<img src="https://sadnhsddereuhpfvdquk.supabase.co/storage/v1/object/sign/BBP%20LOGO/share.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8yNzI5Y2M5OC1mM2IzLTRhNGMtOTAzMC03M2M2MjZlNTM0NTIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJCQlAgTE9HTy9zaGFyZS5wbmciLCJpYXQiOjE3Nzk0MTU2OTgsImV4cCI6MTg3NDAyMzY5OH0.BoJ4ZbiD15lWsE3sYOZr9fKV8lTbYYp5m7CTODX6HNs" class="btn-icon"> 分享圖卡';
        buttonObj.style.borderColor = "var(--tech-blue)";
        buttonObj.style.color = "var(--tech-white)";
        buttonObj.style.backgroundColor = "transparent";
      }, 2000);
    }

    async function reportWithdraw(buttonObj, reportId) {
      if (!supabaseClient) {
        buttonObj.textContent = "❌ 連線失敗";
        return;
      }

      const deviceId = getDeviceId();
      buttonObj.disabled = true;
      buttonObj.textContent = "⏳ 回報中...";

      try {
        const { data, error } = await supabaseClient.rpc("report_noise_withdraw", { p_report_id: reportId, p_device_id: deviceId });
        if (error) throw error;
        const result = data || {};

        if (result.status === "cooldown" || result.status === "updated") {
          buttonObj.textContent = "✓ 已送出通報";
          localStorage.setItem("bbp_noise_reported_" + reportId, String(Date.now()));
          return;
        }

        if (result.status === "deleted") {
          buttonObj.textContent = "✓ 狀況解除，下架中";
          localStorage.setItem("bbp_noise_reported_" + reportId, String(Date.now()));
          setTimeout(function () {
            const targetCardBox = document.getElementById("card-box-" + reportId);
            if (targetCardBox) {
              targetCardBox.classList.add("fade-out");
              setTimeout(async function () {
                await loadDataFromServer(function () { filterData(currentRegion); });
              }, 400);
            } else {
              refreshCurrentRegion();
            }
          }, 600);
          return;
        }

        if (result.status === "not_found") {
          buttonObj.textContent = "⚠️ 紀錄已不存在";
          setTimeout(function () { refreshCurrentRegion(); }, 1000);
          return;
        }

        buttonObj.textContent = "⚠️ 無效操作";
        setTimeout(function () {
          buttonObj.disabled = false;
          buttonObj.textContent = "🛑 設備已撤離";
        }, 2000);

      } catch (error) {
        buttonObj.textContent = "❌ 系統錯誤";
        setTimeout(function () {
          buttonObj.disabled = false;
          buttonObj.textContent = "🛑 設備已撤離";
        }, 2000);
      }
    }
    function enableDesktopHorizontalWheel() {
      const dataScreen = document.getElementById("data-screen");
      if (!dataScreen) return;
    
      let wheelLock = false;
    
      dataScreen.addEventListener("wheel", function (event) {
        if (window.innerWidth <= 768) return;
    
        const isVisible = window.getComputedStyle(dataScreen).display === "flex";
        if (!isVisible) return;
    
        const canScrollHorizontally = dataScreen.scrollWidth > dataScreen.clientWidth;
        if (!canScrollHorizontally) return;
    
        event.preventDefault();
    
        const delta = Math.abs(event.deltaY) > Math.abs(event.deltaX)
          ? event.deltaY
          : event.deltaX;
    
        if (wheelLock) return;
    
        wheelLock = true;
    
        dataScreen.scrollBy({
          left: delta * 2.2,
          behavior: "smooth"
        });
    
        setTimeout(function () {
          wheelLock = false;
        }, 90);
      }, { passive: false });
    }
    function scrollToCard(reportId) {
      const targetCard = document.getElementById("card-box-" + reportId);
      if (targetCard) {
        targetCard.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
      }
    }
  </script>
